using System.Text.Json; public class TemperatureConfigsModel { public double IntervalRealtimeDetailUI { get; set; } = 10000; } string json = "{\"intervalRealtimeDetailUI\": 5000}"; var config = JsonSerializer.Deserialize<TemperatureConfigsModel>(json, new JsonSerializerOptions { PropertyNameCaseInsensitive = true }); Console.WriteLine($"Deserialized: {config.IntervalRealtimeDetailUI}");
