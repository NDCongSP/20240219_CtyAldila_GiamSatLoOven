@page "/createduser"

<RadzenTemplateForm Data="@_model" Submit="@((RegisterModel args) => { Submit(args); })">
    <RadzenRow Gap="2rem" Class="rz-p-0 rz-p-lg-4">
        <RadzenColumn SizeXS="12" SizeMD="12">
            <RadzenStack>
                <RadzenFieldset Text="Thông tin user">
                    <RadzenStack Gap="1rem">
                        <RadzenRow AlignItems="AlignItems.Center">
                            <RadzenColumn SizeXS="12" SizeSM="12">
                                <RadzenText TextStyle="TextStyle.Caption" class="rz-display-flex rz-mt-0 rz-mb-0">Tên user</RadzenText>
                                <RadzenTextBox Name="_txtUserName" TextStyle="TextStyle.Body1" Style="display: block;width: 100%;" 
                                               Value=@_model.UserName Change=@HandleUserNameChange />
                                <RadzenRequiredValidator Component="_txtUserName" Text="Nhập tên user" Popup="false" Style="position: absolute" />
                            </RadzenColumn>
                            <RadzenColumn SizeXS="12" SizeSM="12">
                                <RadzenText TextStyle="TextStyle.Caption" class="rz-display-flex rz-mt-0 rz-mb-0">Email</RadzenText>
                                <RadzenTextBox Name="Email" TextStyle="TextStyle.Body1" Style="display: block;width: 100%;" @bind-Value=@_model.Email />
                                <RadzenEmailValidator Component="Email" Text="Email không hợp lệ" Popup="false" Style="position: absolute" />
                            </RadzenColumn>
                            <RadzenColumn SizeXS="12" SizeMD="12" Class="rz-mt-4">
                                <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat" Shade="Shade.Lighter">
                                    Mật khẩu mặc định là: <b>123@@456</b>
                                </RadzenAlert>
                            </RadzenColumn>
                             <RadzenColumn SizeXS="12" SizeSM="12">
                                <RadzenText TextStyle="TextStyle.Caption" class="rz-display-flex rz-mt-0 rz-mb-0">Phân quyền</RadzenText>
                                <RadzenDropDown Name="_dropDownRoles" @bind-Value=@_model.Roles Data=@_roles Multiple=true AllowClear=true Placeholder="Select roles"
                                                Style="display: block;width:100%"></RadzenDropDown>
                                <RadzenRequiredValidator Component="_dropDownRoles" Text="Chọn quyền" Popup="false" Style="position: absolute" />
                            </RadzenColumn>
                        </RadzenRow>
                    </RadzenStack>
                </RadzenFieldset>
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Center" Gap="1rem" Class="rz-mt-8 rz-mb-4">
        <RadzenButton ButtonType="ButtonType.Submit" Size="ButtonSize.Large" Icon="save" Text="Lưu" />
        @* <RadzenButton ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Large" Icon="cancel" Text="Cancel" Click="@Cancel" /> *@
    </RadzenStack>
</RadzenTemplateForm>