@using GiamSat.Models

<RadzenTemplateForm Data="@_model" Submit="@((RevoConfigModel args) => { Submit(args); })">
    <RadzenStack Gap="1rem">
        <RadzenFieldset Text="@(_isEdit ? "Chỉnh sửa REVO" : "Thêm REVO mới")">
            <RadzenStack Gap="1rem">
                <RadzenFormField Text="ID" class="rz-col-12">
                    <RadzenNumeric @bind-Value="@_model.Id" Disabled="true" Style="width: 100%;" />
                </RadzenFormField>

                <RadzenFormField Text="Tên REVO" class="rz-col-12">
                    <RadzenTextBox @bind-Value="@_model.Name" Placeholder="Nhập tên REVO" Style="width: 100%;" />
                </RadzenFormField>

                <RadzenFormField Text="Loại Máy" class="rz-col-12">
                    <RadzenDropDown @bind-Value=@_model.MachineType
                                    Data="@(Enum.GetValues(typeof(EnumMachineType)).Cast<EnumMachineType>().Select(e => new
                                    {
                                        DisplayValue = e.ToString(),
                                        Value = e
                                    }))"
                                    ValueProperty="Value" TextProperty="DisplayValue"
                                    Style="width: 100%; max-width: 400px;" Name="DropDownBindValue" 
                                    Chips=true Disabled="false"
                                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                    FilterOperator="StringFilterOperator.Contains"
                                    AllowFiltering="true" />
                </RadzenFormField>

                <RadzenFormField Text="Đường dẫn" class="rz-col-12">
                    <RadzenTextBox @bind-Value="@_model.Path" Placeholder="Nhập đường dẫn" Style="width: 100%;" />
                </RadzenFormField>

                <RadzenFormField Text="Chuỗi kết nối Access DB" class="rz-col-12">
                    <RadzenTextBox @bind-Value="@_model.ConstringAccessDb" Placeholder="Provider=Microsoft.Jet.OLEDB.4.0;Data Source=..." Style="width: 100%;" Rows="2" />
                </RadzenFormField>

                <RadzenFormField Text="Pulse/Rev (độ phân giải driver)" class="rz-col-12">
                    <RadzenNumeric @bind-Value="@_model.Pulse_Rev" Min="1" Style="width: 100%;" />
                </RadzenFormField>

                <RadzenFormField Text="Pulse/Rev Offset (bù xung tốc độ)" class="rz-col-12">
                    <RadzenNumeric @bind-Value="@_model.Pulse_rev_Offset" Style="width: 100%;" Placeholder="0" />
                </RadzenFormField>

                <RadzenFormField Text="Interval Reset Shaft (ms)" class="rz-col-12">
                    <RadzenNumeric @bind-Value="@_model.IntervalResetShaft" Min="0" Style="width: 100%;" Placeholder="3000" />
                </RadzenFormField>

                <RadzenStack Gap="0.5rem" class="rz-pt-2">
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">Chế độ lưu dữ liệu</RadzenText>
                    <RadzenRadioButtonList @bind-Value="@_model.SaveMode" TValue="EnumSaveMode" Orientation="Orientation.Vertical">
                        <Items>
                            <RadzenRadioButtonListItem Text="Save (shaft)" Value="EnumSaveMode.Save" />
                            <RadzenRadioButtonListItem Text="Save all (shaft+step)" Value="EnumSaveMode.SaveAll" />
                        </Items>
                    </RadzenRadioButtonList>
                </RadzenStack>
            </RadzenStack>
        </RadzenFieldset>

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
            <RadzenButton Text="Hủy" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close())" />
            <RadzenButton Text="@(_isEdit ? "Cập nhật" : "Thêm")" ButtonStyle="ButtonStyle.Primary" Type="Submit" />
        </RadzenStack>
    </RadzenStack>
</RadzenTemplateForm>
