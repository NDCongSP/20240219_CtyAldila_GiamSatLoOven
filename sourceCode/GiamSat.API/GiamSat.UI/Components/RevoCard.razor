@using GiamSat.Models

<RadzenCard class="@($"revo-card rz-shadow-3 {GetCardConnectionClass()}")" Style="@GetCardStyle()">
    <RadzenStack Gap="0.5rem">
        <!-- REVO Name and Detail Button -->
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
            <RadzenText TextStyle="TextStyle.H6" Style="font-weight: 600;">@RevoData.RevoName</RadzenText>
            <RadzenButton Icon="info" 
                        Text="Chi tiết" 
                        ButtonStyle="ButtonStyle.Info" 
                        Size="ButtonSize.Small"
                        Click="@OnDetailClick" />
        </RadzenStack>

        <!-- Part Info -->
        <div class="info-grid">
            <div class="info-item">
                <span class="info-label">PART:</span>
                <span class="info-value">@(RevoData.Part ?? "N/A")</span>
            </div>
            <div class="info-item">
                <span class="info-label">REV:</span>
                <span class="info-value">@(RevoData.Rev ?? "NC")</span>
            </div>
        </div>

        <div class="info-grid">
            <div class="info-item">
                <span class="info-label">COLOR:</span>
                <span class="info-value">@(RevoData.ColorCode ?? "none")</span>
            </div>
            <div class="info-item">
                <span class="info-label">MANDREL:</span>
                <span class="info-value">@(RevoData.Mandrel ?? "N/A")</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(RevoData.MandrelStart))
        {
            <div class="info-item">
                <span class="info-label">SIZE:</span>
                <span class="info-value">@RevoData.MandrelStart</span>
            </div>
        }

        <!-- Steps List (all steps with scroll, default showing 3.5 steps) -->
        @if (RevoData.Steps != null && RevoData.Steps.Any(s => s.Visible.HasValue && s.Visible.Value == true))
        {
            <div class="steps-container" @ref="stepsContainerRef">
                @{
                    var visibleSteps = RevoData.Steps.Where(s => s.Visible.HasValue && s.Visible.Value == true).OrderBy(s => s.StepIndex).ToList();
                    var now = DateTime.Now;
                    
                    // Find the running step (startAt != null, endAt == null) or the first step
                    var runningStepIndex = -1;
                    for (int i = 0; i < visibleSteps.Count; i++)
                    {
                        var step = visibleSteps[i];
                        if (step.StartAt.HasValue && !step.EndAt.HasValue)
                        {
                            runningStepIndex = i;
                            break;
                        }
                    }
                    
                    // If no running step found, start from first step
                    var startIndex = runningStepIndex >= 0 ? runningStepIndex : 0;
                }
                @for (int i = 0; i < visibleSteps.Count; i++)
                {
                    var step = visibleSteps[i];
                    var stepNumber = i + 1;
                    
                    <div class="step-item @GetStepClass(step)" data-step-index="@i">
                        <div class="step-number">@stepNumber</div>
                        <div class="step-content">
                            <div class="step-name">@(step.StepName ?? $"REVO-STEP-{step.StepIndex}")</div>
                        </div>
                        @if (step.StartAt.HasValue)
                        {
                            <div class="step-time">
                                @if (step.EndAt.HasValue)
                                {
                                    <span>@step.StartAt.Value.ToString("HH:mm") → @step.EndAt.Value.ToString("HH:mm")</span>
                                }
                                else
                                {
                                    <span>@step.StartAt.Value.ToString("HH:mm") → ...</span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </RadzenStack>
</RadzenCard>

@code {
    [Parameter]
    public RevoRealtimeModel RevoData { get; set; } = new RevoRealtimeModel();

    [Parameter]
    public EventCallback OnDetailClick { get; set; }

    private ElementReference stepsContainerRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && RevoData.Steps != null)
        {
            var visibleSteps = RevoData.Steps.Where(s => s.Visible.HasValue && s.Visible.Value == true).OrderBy(s => s.StepIndex).ToList();
            
            // Find the running step index
            var runningStepIndex = -1;
            for (int i = 0; i < visibleSteps.Count; i++)
            {
                var step = visibleSteps[i];
                if (step.StartAt.HasValue && !step.EndAt.HasValue)
                {
                    runningStepIndex = i;
                    break;
                }
            }
            
            // Scroll to show 3.5 steps starting from running step (or first step)
            if (runningStepIndex >= 0 || visibleSteps.Count > 0)
            {
                var startIndex = runningStepIndex >= 0 ? runningStepIndex : 0;
                await ScrollToStep(startIndex);
            }
        }
    }

    private async Task ScrollToStep(int stepIndex)
    {
        // Calculate scroll position to show 3.5 steps
        // Each step is approximately 50px (min-height) + 8px (gap) = 58px
        // 3.5 steps = 3.5 * 58px = 203px
        try
        {
            // Use JavaScript to scroll
            var stepHeight = 58; // 50px min-height + 8px gap
            var scrollPosition = stepIndex * stepHeight;
            
            await _js.InvokeVoidAsync("scrollStepsContainer", stepsContainerRef, scrollPosition);
        }
        catch
        {
            // Ignore JS errors - scroll will happen naturally or user can scroll manually
        }
    }

    private string GetCardConnectionClass()
    {
        return RevoData.PlcConnected == true ? "card-connected" : "card-disconnected";
    }

    private string GetCardStyle()
    {
        if (RevoData.PlcConnected == true)
        {
            return "background-color: #e8f5e9 !important; border: 2px solid #4caf50 !important;";
        }
        else
        {
            return "background-color: #ffebee !important; border: 2px solid #f44336 !important;";
        }
    }

    private string GetStepClass(RevoStep step)
    {
        if (!step.Visible.HasValue || step.Visible.Value == false)
            return "";

        var now = DateTime.Now;
        var classes = new List<string>();

        // Enable status - if disabled, always black
        if (step.Enable.HasValue && step.Enable.Value == false)
        {
            classes.Add("step-disabled"); // Black
        }
        else
        {
            // Check for running step (startAt != null, endAt == null)
            if (step.StartAt.HasValue && !step.EndAt.HasValue)
            {
                classes.Add("step-running"); // White - running
            }
            // Time-based status
            else if (step.StartAt.HasValue && step.EndAt.HasValue)
            {
                if (now < step.StartAt.Value)
                {
                    classes.Add("step-pending"); // Gray - not started
                }
                else if (now >= step.StartAt.Value && now <= step.EndAt.Value)
                {
                    classes.Add("step-running"); // White - running
                }
                else
                {
                    classes.Add("step-completed"); // Light blue - completed
                }
            }
            else
            {
                // No time info, default to pending
                classes.Add("step-pending");
            }
        }

        return string.Join(" ", classes);
    }
}
