@page "/temperature/config"
@using Radzen
@using Radzen.Blazor
@using GiamSat.APIClient
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = GiamSat.Models.AppPermissions.Temperature_Config_View)]


<RadzenRow Gap="1rem">
    <RadzenColumn Size="12">
        <RadzenCard class="rz-shadow-3">
            <RadzenStack Gap="1rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenText TextStyle="TextStyle.H5">Cấu hình Vị trí Đo Nhiệt độ</RadzenText>
                    
                    <AuthorizeView Policy="@GiamSat.Models.AppPermissions.Temperature_Config_Create">
                        <RadzenButton Icon="add_circle" 
                                    Text="Thêm Vị trí" 
                                    ButtonStyle="ButtonStyle.Success" 
                                    Click="@InsertRow" />
                    </AuthorizeView>
                    
                </RadzenStack>

                @if (_isLoading)
                {
                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                    <RadzenText>Đang tải dữ liệu...</RadzenText>
                }
                else
                {
                    <RadzenCard class="rz-mb-3 rz-background-color-info-lighter">
                        <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2">Cấu hình chung toàn hệ thống</RadzenText>
                        <RadzenRow Gap="1rem">
                            <RadzenColumn Size="12" SizeMD="3">
                                <RadzenLabel Text="Chu kỳ UI Web (ms)" Component="timerRealtimeUI" class="rz-mb-1" />
                                <RadzenNumeric @bind-Value="_config.IntervalRealtimeUI" Name="timerRealtimeUI" Style="width:100%" Format="n0" />
                            </RadzenColumn>
                            <RadzenColumn Size="12" SizeMD="3">
                                <RadzenLabel Text="Chu kỳ SCADA (ms)" Component="timerRealtime" class="rz-mb-1" />
                                <RadzenNumeric @bind-Value="_config.IntervalRealtime" Name="timerRealtime" Style="width:100%" Format="n0" />
                            </RadzenColumn>
                            <RadzenColumn Size="12" SizeMD="3">
                                <RadzenLabel Text="Chu kỳ Datalog (ms)" Component="timerDatalog" class="rz-mb-1" />
                                <RadzenNumeric @bind-Value="_config.IntervalDataLog" Name="timerDatalog" Style="width:100%" Format="n0" />
                            </RadzenColumn>
                            <RadzenColumn Size="12" SizeMD="3">
                                <RadzenLabel Text="Nhấp nháy báo động (ms)" Component="timeBlink" class="rz-mb-1" />
                                <RadzenNumeric @bind-Value="_config.TimeBlinkAlarm" Name="timeBlink" Style="width:100%" Format="n0" />
                            </RadzenColumn>
                        </RadzenRow>
                        <RadzenRow Gap="1rem" class="rz-mt-3">
                            <RadzenColumn Size="12" SizeMD="3">
                                <RadzenLabel Text="Chu kỳ Chi tiết UI (ms)" Component="timerRealtimeDetailUI" class="rz-mb-1" />
                                <RadzenNumeric @bind-Value="_config.IntervalRealtimeDetailUI" Name="timerRealtimeDetailUI" Style="width:100%" Format="n0" />
                            </RadzenColumn>
                        </RadzenRow>
                        <RadzenRow class="rz-mt-3">
                            <RadzenColumn Size="12">
                                <AuthorizeView Policy="@GiamSat.Models.AppPermissions.Temperature_Config_Edit">
                                    <RadzenButton Text="Lưu Cấu Hình Chung" ButtonStyle="ButtonStyle.Primary" Click="@SaveGlobalConfig" />
                                </AuthorizeView>
                            </RadzenColumn>
                        </RadzenRow>
                    </RadzenCard>
                    <RadzenDataGrid @ref="_dataGrid" 
                                  Data="@_config.LocationsConfig" 
                                  TItem="TemperatureLocationModel" 
                                  AllowPaging="true" 
                                  PageSize="10"
                                  PageSizeOptions="@(new int[] { 5, 10, 20, 50 })"
                                  AllowSorting="true"
                                  EditMode="DataGridEditMode.Single"
                                  RowUpdate="@OnUpdateRow"
                                  RowCreate="@OnCreateRow"
                                  class="rz-mt-3">
                        <Columns>
                            <RadzenDataGridColumn TItem="TemperatureLocationModel" Property="Id" Title="ID" Width="70px" TextAlign="TextAlign.Center">
                                <EditTemplate Context="item">
                                    <RadzenNumeric @bind-Value="item.Id" Style="width:100%" Disabled="true" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            
                            <RadzenDataGridColumn TItem="TemperatureLocationModel" Property="Name" Title="Tên vị trí" Width="150px">
                                <EditTemplate Context="item">
                                    <RadzenTextBox @bind-Value="item.Name" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            
                            <RadzenDataGridColumn TItem="TemperatureLocationModel" Property="Path" Title="Đường dẫn thẻ" Width="200px">
                                <EditTemplate Context="item">
                                    <RadzenTextBox @bind-Value="item.Path" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="TemperatureLocationModel" Property="Offset" Title="Offset" Width="80px">
                                <EditTemplate Context="item">
                                    <RadzenNumeric @bind-Value="item.Offset" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="TemperatureLocationModel" Property="HightLevel" Title="Ngưỡng cao" Width="100px">
                                <EditTemplate Context="item">
                                    <RadzenNumeric @bind-Value="item.HightLevel" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="TemperatureLocationModel" Property="LowLevel" Title="Ngưỡng thấp" Width="100px">
                                <EditTemplate Context="item">
                                    <RadzenNumeric @bind-Value="item.LowLevel" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="TemperatureLocationModel" Title="Hành động" Width="150px" TextAlign="TextAlign.Center" Frozen="true" FrozenPosition="FrozenColumnPosition.Right">
                                <Template Context="item">
                                    
                                    <AuthorizeView Policy="@GiamSat.Models.AppPermissions.Temperature_Config_Edit" Context="authContext">
                                        <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Variant="Variant.Flat" Click="@(() => EditRow(item))" />
                                    </AuthorizeView>
                                    
                                    <AuthorizeView Policy="@GiamSat.Models.AppPermissions.Temperature_Config_Delete" Context="authContext">
                                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Variant="Variant.Flat" Click="@(() => DeleteRow(item))" class="rz-ml-1" />
                                    </AuthorizeView>
                                    
                                </Template>
                                <EditTemplate Context="item">
                                    <RadzenButton Icon="save" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small" Variant="Variant.Flat" Click="@(() => _dataGrid.UpdateRow(item))" />
                                    <RadzenButton Icon="cancel" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Variant="Variant.Flat" Click="@(() => CancelEdit(item))" class="rz-ml-1" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                }
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
