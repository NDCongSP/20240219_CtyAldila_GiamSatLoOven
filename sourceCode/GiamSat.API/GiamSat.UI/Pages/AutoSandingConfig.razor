@page "/autosanding/config"
@using GiamSat.Models
@using GiamSat.APIClient
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = AppPermissions.Sanding_Config_View)]

<RadzenRow Gap="1rem">
    <RadzenColumn Size="12">
        <RadzenCard class="rz-shadow-3">
            <RadzenStack Gap="0.75rem">

                @* Header *@
                <RadzenStack Orientation="Orientation.Horizontal"
                             AlignItems="AlignItems.Center"
                             JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenText TextStyle="TextStyle.H5">Cấu hình Auto Sanding</RadzenText>
                </RadzenStack>

                @* Tabs *@
                <RadzenTabs @bind-SelectedIndex="_selectedTab" RenderMode="TabRenderMode.Client">
                    <Tabs>

                        @* ══════════════════════════════════
                           TAB 1: CẤU HÌNH CHUNG
                           ══════════════════════════════════ *@
                        <RadzenTabsItem Text="Cấu hình chung" Icon="settings">
                            <RadzenStack Gap="0.75rem" class="rz-pt-3">

                                <RadzenStack Orientation="Orientation.Horizontal"
                                             AlignItems="AlignItems.Center"
                                             JustifyContent="JustifyContent.SpaceBetween">
                                    <RadzenText TextStyle="TextStyle.Subtitle1">Danh sách Part</RadzenText>
                                    <RadzenButton Icon="add_circle" Text="Thêm Part"
                                                  ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small"
                                                  Click="@OnAddPart" />
                                </RadzenStack>

                                @if (_isLoading)
                                {
                                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                                    <RadzenText>Đang tải dữ liệu...</RadzenText>
                                }
                                else if (_parts.Count == 0)
                                {
                                    <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false">
                                        Chưa có part nào. Nhấn "Thêm Part" để tạo mới.
                                    </RadzenAlert>
                                }
                                else
                                {
                                    @* Bảng Part kiểu giống Excel *@
                                    <div style="overflow-x:auto">
                                        <table class="as-config-table">
                                            <thead>
                                                <tr>
                                                    <th rowspan="2">Item Number</th>
                                                    <th rowspan="2" style="color:#c62828">Length</th>
                                                    <th rowspan="2">Freq Target</th>
                                                    <th rowspan="2" style="color:#c62828">Fre -</th>
                                                    <th rowspan="2" style="color:#c62828">Fre +</th>
                                                    <th rowspan="2" style="color:#c62828">Formula-F</th>
                                                    <th rowspan="2" style="color:#1565c0">A</th>
                                                    <th rowspan="2" style="color:#1565c0">B</th>
                                                    <th rowspan="2" style="color:#1565c0">C</th>
                                                    <th rowspan="2" style="color:#1565c0">D</th>
                                                    <th colspan="3" class="th-tipod">Diam_LL / Diam_UL / Tip OD LENGTH</th>
                                                    <th rowspan="2">Hành động</th>
                                                </tr>
                                                <tr>
                                                    <th class="th-tipod">Data Điểm 1</th>
                                                    <th class="th-tipod">Data Điểm 2</th>
                                                    <th class="th-tipod">Data Điểm 3</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var p in _parts)
                                                {
                                                    <tr>
                                                        <td class="td-item">@p.PartName</td>
                                                        <td class="td-red">@p.Length?.ToString("F1")</td>
                                                        <td>@p.FreqTarget?.ToString("F1")</td>
                                                        <td class="td-red">@p.Set_Freq_Offset_Low?.ToString("F1")</td>
                                                        <td class="td-red">@p.Set_Freq_Offset_Hight?.ToString("F1")</td>
                                                        <td class="td-red">@p.Formula_F?.ToString("F0")</td>
                                                        <td class="td-blue">@p.A?.ToString("F3")</td>
                                                        <td class="td-blue">@p.B?.ToString("F3")</td>
                                                        <td class="td-blue">@p.C?.ToString("F3")</td>
                                                        <td class="td-blue">@p.D?.ToString("F3")</td>

                                                        @* 3 Data Điểm TipOD *@
                                                        <td class="td-tipod">
                                                            <div class="tipod-cell">
                                                                <span>@p.Diam_LL_1?.ToString("F2")</span>
                                                                <span>@p.Diam_UL_1?.ToString("F2")</span>
                                                                <span class="tipod-label">@(p.TipOdLength_1 ?? "—")</span>
                                                            </div>
                                                        </td>
                                                        <td class="td-tipod">
                                                            <div class="tipod-cell">
                                                                <span>@p.Diam_LL_2?.ToString("F2")</span>
                                                                <span>@p.Diam_UL_2?.ToString("F2")</span>
                                                                <span class="tipod-label">@(p.TipOdLength_2 ?? "—")</span>
                                                            </div>
                                                        </td>
                                                        <td class="td-tipod">
                                                            <div class="tipod-cell">
                                                                <span>@p.Diam_LL_3?.ToString("F2")</span>
                                                                <span>@p.Diam_UL_3?.ToString("F2")</span>
                                                                <span class="tipod-label">@(p.TipOdLength_3 ?? "—")</span>
                                                            </div>
                                                        </td>

                                                        <td class="td-action">
                                                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.3rem" JustifyContent="JustifyContent.Center">
                                                                <RadzenButton Icon="edit"
                                                                              ButtonStyle="ButtonStyle.Primary"
                                                                              Size="ButtonSize.Small"
                                                                              Variant="Variant.Flat"
                                                                              Click="@(() => OnEditPart(p))"
                                                                              title="Chỉnh sửa" />
                                                                <RadzenButton Icon="delete"
                                                                              ButtonStyle="ButtonStyle.Danger"
                                                                              Size="ButtonSize.Small"
                                                                              Variant="Variant.Flat"
                                                                              Click="@(() => OnDeletePart(p))"
                                                                              title="Xóa" />
                                                            </RadzenStack>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </RadzenStack>
                        </RadzenTabsItem>

                        @* ══════════════════════════════════
                           TAB 2: TÍNH ABCD
                           ══════════════════════════════════ *@
                        <RadzenTabsItem Text="Tính A,B,C,D" Icon="calculate">
                            <RadzenStack Gap="1rem" class="rz-pt-3">

                                @* ── Bộ lọc load data từ DB ── *@
                                <RadzenCard class="rz-background-color-base-100 rz-p-3" style="border-left:4px solid var(--rz-primary)">
                                    <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2" style="color:var(--rz-primary)">Tham số load dữ liệu từ DB</RadzenText>

                                    @* Dòng 1: Part + Work + Formular *@
                                    <RadzenRow Gap="0.75rem" class="rz-mb-2">
                                        <RadzenColumn Size="12" SizeMD="4">
                                            <RadzenFormField Text="Chọn Part" Variant="Variant.Outlined" Style="width:100%">
                                                <RadzenDropDown @bind-Value="_selectedPartId"
                                                                Data="@_parts"
                                                                TextProperty="PartName"
                                                                ValueProperty="Id"
                                                                Placeholder="-- Chọn part --"
                                                                Style="width:100%"
                                                                Change="@OnPartSelected" />
                                            </RadzenFormField>
                                        </RadzenColumn>
                                        <RadzenColumn Size="12" SizeMD="4">
                                            <RadzenFormField Text="Work Order" Variant="Variant.Outlined" Style="width:100%">
                                                <RadzenTextBox @bind-Value="_work" Placeholder="VD: 1794406" Style="width:100%" />
                                            </RadzenFormField>
                                        </RadzenColumn>
                                        <RadzenColumn Size="12" SizeMD="4">
                                            <RadzenFormField Text="Formular" Variant="Variant.Outlined" Style="width:100%">
                                                <RadzenDropDown @bind-Value="_formular"
                                                                Data="@(new[]{1,2,3})"
                                                                Style="width:100%" />
                                            </RadzenFormField>
                                        </RadzenColumn>
                                    </RadzenRow>

                                    @* Dòng 2: Offset Fre1 / Fre2 / Spine *@
                                    <RadzenRow Gap="0.75rem" class="rz-mb-2">
                                        <RadzenColumn Size="12" SizeMD="4">
                                            <RadzenFormField Text="Offset Fre1 (CPM)" Variant="Variant.Outlined" Style="width:100%">
                                                <RadzenNumeric @bind-Value="_offsetFre1" Format="F2" Style="width:100%" TValue="double" />
                                            </RadzenFormField>
                                        </RadzenColumn>
                                        <RadzenColumn Size="12" SizeMD="4">
                                            <RadzenFormField Text="Offset Fre2 (CPM)" Variant="Variant.Outlined" Style="width:100%">
                                                <RadzenNumeric @bind-Value="_offsetFre2" Format="F2" Style="width:100%" TValue="double" />
                                            </RadzenFormField>
                                        </RadzenColumn>
                                        <RadzenColumn Size="12" SizeMD="4">
                                            <RadzenFormField Text="Offset Spine" Variant="Variant.Outlined" Style="width:100%">
                                                <RadzenNumeric @bind-Value="_offsetSpine" Format="F2" Style="width:100%" TValue="double" />
                                            </RadzenFormField>
                                        </RadzenColumn>
                                    </RadzenRow>

                                    @* Dòng 3: Motor speed range + Load Data button *@
                                    <RadzenRow Gap="0.75rem" AlignItems="AlignItems.End">
                                        <RadzenColumn Size="6" SizeMD="2">
                                            <RadzenFormField Text="Tốc độ From (RPM)" Variant="Variant.Outlined" Style="width:100%">
                                                <RadzenNumeric @bind-Value="_motorFrom" Format="F0" Style="width:100%" TValue="double" />
                                            </RadzenFormField>
                                        </RadzenColumn>
                                        <RadzenColumn Size="6" SizeMD="2">
                                            <RadzenFormField Text="To (RPM)" Variant="Variant.Outlined" Style="width:100%">
                                                <RadzenNumeric @bind-Value="_motorTo" Format="F0" Style="width:100%" TValue="double" />
                                            </RadzenFormField>
                                        </RadzenColumn>
                                        <RadzenColumn Size="6" SizeMD="2">
                                            <RadzenFormField Text="Bước nhảy (RPM)" Variant="Variant.Outlined" Style="width:100%">
                                                <RadzenNumeric @bind-Value="_motorStep" Format="F0" Style="width:100%" TValue="double" Min="1" />
                                            </RadzenFormField>
                                        </RadzenColumn>
                                        <RadzenColumn Size="6" SizeMD="6">
                                            <RadzenButton Icon="download" Text="Load Data từ DB"
                                                          ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Medium"
                                                          Click="@OnLoadDataFromDB" IsBusy="@_isLoadingCalc"
                                                          BusyText="Đang load..." />
                                        </RadzenColumn>
                                    </RadzenRow>
                                </RadzenCard>

                                @* ── Nút thao tác bảng ── *@
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" style="flex-wrap:wrap">
                                    <RadzenButton Icon="add" Text="Thêm dòng" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@OnAddTestRow" />
                                    <RadzenButton Icon="delete_sweep" Text="Xóa dòng cuối" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@OnRemoveLastRow" />
                                    <RadzenButton Icon="data_object" Text="Fake Data" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@OnLoadFakeData" />
                                    <RadzenButton Icon="functions" Text="Tính A,B,C,D" ButtonStyle="ButtonStyle.Warning" Size="ButtonSize.Medium" Click="@OnCalculateABCD" />
                                    @if (_abcdCalculated)
                                    {
                                        <RadzenButton Icon="save" Text="Áp dụng &amp; Lưu DB"
                                                      ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Medium"
                                                      Click="@OnApplyAbcdToPart" IsBusy="@_isSaving" />
                                    }
                                </RadzenStack>

                                @* Hướng dẫn quy trình *@
                                <RadzenCard Style="border-left: 4px solid var(--rz-info); background: var(--rz-info-lighter)">
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                                                 Gap="0.5rem" style="cursor:pointer" @onclick="@(() => _showGuide = !_showGuide)">
                                        <RadzenIcon Icon="menu_book" Style="color:var(--rz-info)" />
                                        <RadzenText TextStyle="TextStyle.Subtitle2" Style="color:var(--rz-info); margin:0">
                                            Hướng dẫn quy trình tìm tham số A, B, C, D
                                        </RadzenText>
                                        <RadzenIcon Icon="@(_showGuide ? "expand_less" : "expand_more")" Style="color:var(--rz-info); margin-left:auto" />
                                    </RadzenStack>
                                    @if (_showGuide)
                                    {
                                        <hr style="border-color:var(--rz-info-light); margin:0.5rem 0" />
                                        <div class="guide-body">

                                            @* BƯỚC 1 *@
                                            <div class="guide-step">
                                                <span class="guide-badge" style="background:var(--rz-warning)">1</span>
                                                <div style="flex:1">
                                                    <strong>Sand lần 1 — Thu thập Fre1 &amp; Stiffness Z</strong>
                                                    <p class="guide-p">Chạy từng shaft qua máy sand với <em>1 tốc độ belt cố định</em>. Sau khi sand xong, đo ngay:</p>
                                                    <ul class="guide-ul">
                                                        <li><em style="color:#e65100">Fre1 (CPM)</em> – tần số dao động của shaft đo bằng thiết bị rung.</li>
                                                        <li><em style="color:#e65100">Stiffness Z (Kg)</em> – độ cứng đo theo chiều Z (lực / độ võng).</li>
                                                    </ul>
                                                    <p class="guide-p">Nhập cả hai giá trị vào bảng. Mỗi shaft = 1 dòng.</p>
                                                </div>
                                            </div>

                                            @* BƯỚC 2 *@
                                            <div class="guide-step">
                                                <span class="guide-badge" style="background:var(--rz-info)">2</span>
                                                <div style="flex:1">
                                                    <strong>Sand lần 2 — Thu thập RPM, Fre2 &amp; Stiffness Y</strong>
                                                    <p class="guide-p">Sand lại các shaft theo từng mức tốc độ belt tăng dần (VD: 100, 200, 300, 400, 500 RPM — cứ 2 shaft/mức). Sau mỗi lần sand, đo:</p>
                                                    <ul class="guide-ul">
                                                        <li><em style="color:#0d47a1">RPM</em> – tốc độ belt đã dùng.</li>
                                                        <li><em style="color:#1b5e20">Fre2 (CPM)</em> – tần số dao động sau sand lần 2.</li>
                                                        <li><em style="color:#1b5e20">Stiffness Y (Kg)</em> – độ cứng theo chiều Y sau sand lần 2.</li>
                                                    </ul>
                                                    <p class="guide-p">Cột <em style="color:#6a1b9a"><strong>Freq Diff S</strong> = Fre1 − Fre2</em> được tính tự động — đây là lượng tần số thay đổi do sand.</p>
                                                </div>
                                            </div>

                                            @* BƯỚC 3 - TÍNH A, B *@
                                            <div class="guide-step">
                                                <span class="guide-badge" style="background:var(--rz-primary)">3a</span>
                                                <div style="flex:1">
                                                    <strong>Tính A, B — Hồi quy tuyến tính: Y = A·Z + B</strong>
                                                    <p class="guide-p">
                                                        Mục tiêu: tìm đường thẳng khớp nhất với tập dữ liệu <em>(Stiffness Y → Fre2)</em>.<br />
                                                        Đặt: <code>x = Stiffness Y (Kg)</code>, <code>y = Fre2 (CPM)</code>, <code>n = số dòng dữ liệu</code>.
                                                    </p>
                                                    <div class="guide-math-block">
                                                        <div class="guide-math-title">Công thức hồi quy tuyến tính (Ordinary Least Squares):</div>
                                                        <div class="guide-math-row">
                                                            <span class="guide-math-label" style="color:var(--rz-primary)">A (slope)</span>
                                                            <span class="guide-math-eq">= <strong>(n·Σ(x·y) − Σx·Σy) / (n·Σx² − (Σx)²)</strong></span>
                                                        </div>
                                                        <div class="guide-math-row">
                                                            <span class="guide-math-label" style="color:var(--rz-primary)">B (intercept)</span>
                                                            <span class="guide-math-eq">= <strong>(Σy − A·Σx) / n</strong></span>
                                                        </div>
                                                        <div class="guide-math-row">
                                                            <span class="guide-math-label">R² (độ khớp)</span>
                                                            <span class="guide-math-eq">= <strong>1 − SS<sub>res</sub>/SS<sub>tot</sub></strong> &nbsp;|&nbsp; SS<sub>tot</sub> = Σ(y−ȳ)² &nbsp;|&nbsp; SS<sub>res</sub> = Σ(y−(A·x+B))²</span>
                                                        </div>
                                                    </div>
                                                    <p class="guide-p guide-example">
                                                        <strong>Ví dụ (2 dòng):</strong> x=[2.546, 2.526], y=[308.1, 306.3], n=2<br />
                                                        Σx=5.072 | Σy=614.4 | Σxy=2.546×308.1+2.526×306.3=1562.3+773.3=... → A≈102, B≈46<br />
                                                        <em>Nghĩa là: mỗi kg Stiffness tăng thêm → Fre2 tăng ~102 CPM.</em>
                                                    </p>
                                                </div>
                                            </div>

                                            @* BƯỚC 3b - TÍNH C, D *@
                                            <div class="guide-step">
                                                <span class="guide-badge" style="background:var(--rz-success)">3b</span>
                                                <div style="flex:1">
                                                    <strong>Tính C, D — Hồi quy tuyến tính: R = C·S + D</strong>
                                                    <p class="guide-p">
                                                        Mục tiêu: tìm mối quan hệ giữa <em>lượng tần số thay đổi → tốc độ belt cần thiết</em>.<br />
                                                        Đặt: <code>x = Freq Diff S = Fre1−Fre2 (CPM)</code>, <code>y = RPM</code>, <code>n = số dòng</code>.
                                                    </p>
                                                    <div class="guide-math-block">
                                                        <div class="guide-math-title">Cùng công thức OLS, nhưng trên tập dữ liệu khác:</div>
                                                        <div class="guide-math-row">
                                                            <span class="guide-math-label" style="color:var(--rz-success)">C (slope)</span>
                                                            <span class="guide-math-eq">= <strong>(n·Σ(S·R) − ΣS·ΣR) / (n·ΣS² − (ΣS)²)</strong></span>
                                                        </div>
                                                        <div class="guide-math-row">
                                                            <span class="guide-math-label" style="color:var(--rz-success)">D (intercept)</span>
                                                            <span class="guide-math-eq">= <strong>(ΣR − C·ΣS) / n</strong></span>
                                                        </div>
                                                    </div>
                                                    <p class="guide-p guide-example">
                                                        <strong>Ý nghĩa thực tế:</strong> Biết shaft cần sand thêm S CPM, hệ thống tính ngược R = C·S + D để chọn đúng tốc độ belt.<br />
                                                        <em>Ví dụ: S=5 CPM, C=48, D=−40 → R = 48×5+(−40) = 200 RPM.</em>
                                                    </p>
                                                </div>
                                            </div>

                                            @* BƯỚC 3c - F *@
                                            <div class="guide-step">
                                                <span class="guide-badge" style="background:var(--rz-warning-dark)">3c</span>
                                                <div style="flex:1">
                                                    <strong>Hệ số F — Bù hao mòn belt theo số shaft đã mài (X)</strong>
                                                    <p class="guide-p">Belt càng mòn, hiệu suất sand càng giảm → cần tăng tốc độ để bù. Công thức đa thức bậc 3:</p>
                                                    <div class="guide-math-block">
                                                        <div class="guide-math-row">
                                                            <span class="guide-math-label" style="color:var(--rz-warning-dark)">F(X)</span>
                                                            <span class="guide-math-eq">= <strong>(−0.0006·X³ + 0.3·X² − 72.2·X) × (−0.001)</strong></span>
                                                        </div>
                                                        <div class="guide-math-row">
                                                            <span class="guide-math-label">X</span>
                                                            <span class="guide-math-eq">= số shaft đã mài kể từ lần thay belt</span>
                                                        </div>
                                                    </div>
                                                    <p class="guide-p guide-example">
                                                        <em>X=0 → F=0 (belt mới, không bù). X=100 → F tăng dần → RPM được cộng thêm F để giữ chất lượng sand ổn định.</em>
                                                    </p>
                                                </div>
                                            </div>

                                            @* BƯỚC 4 *@
                                            <div class="guide-step">
                                                <span class="guide-badge" style="background:var(--rz-danger)">4</span>
                                                <div style="flex:1">
                                                    <strong>Kiểm tra R² và lưu DB</strong>
                                                    <ul class="guide-ul">
                                                        <li><strong>R² &gt; 0.95</strong>: dữ liệu đủ tuyến tính, A/B/C/D đáng tin cậy → nhấn <strong>"Áp dụng &amp; Lưu DB"</strong>.</li>
                                                        <li><strong>R² = 0.80–0.95</strong>: chấp nhận được nhưng nên đo thêm dữ liệu.</li>
                                                        <li><strong>R² &lt; 0.80</strong>: dữ liệu nhiễu, kiểm tra lại phép đo trước khi lưu.</li>
                                                    </ul>
                                                    <p class="guide-p">Sau khi lưu, hệ thống sẽ dùng công thức <code>RPM = C·(FreqTarget − FreqMeasured) + D + F(X)</code> để tự động điều chỉnh tốc độ belt cho part này.</p>
                                                </div>
                                            </div>

                                        </div>
                                    }
                                </RadzenCard>

                                @* Bảng nhập dữ liệu test *@
                                <RadzenCard class="rz-background-color-base-200 rz-p-2">
                                    <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2">Dữ liệu đo test (Sand 1 → Sand 2)</RadzenText>
                                    <div style="overflow-x:auto">
                                        <table class="as-test-table">
                                            <thead>
                                                <tr>
                                                    <th rowspan="2" class="col-idx">#</th>
                                                    <th colspan="2" class="group-sand1">1st After Sanding</th>
                                                    <th rowspan="2" class="group-rpm">Fix Belt<br />Rotation (RPM)</th>
                                                    <th colspan="3" class="group-sand2">Formula calculation – 2nd After Sanding</th>
                                                </tr>
                                                <tr>
                                                    <th class="group-sand1">Fre1 (CPM)</th>
                                                    <th class="group-sand1">Stiffness Z (Kg)</th>
                                                    <th class="group-sand2">Fre2 (CPM)</th>
                                                    <th class="group-sand2">Stiffness Y (Kg)</th>
                                                    <th class="group-sand2">Freq Diff S<br />(Fre1–Fre2)</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var row in _testRows)
                                                {
                                                    <tr>
                                                        <td class="col-idx">@row.RowIndex</td>
                                                        <td><RadzenNumeric @bind-Value="row.Fre1" Format="F1" Style="width:90px" TValue="double" /></td>
                                                        <td><RadzenNumeric @bind-Value="row.StiffnessZ" Format="F3" Style="width:90px" TValue="double" /></td>
                                                        <td><RadzenNumeric @bind-Value="row.BeltRotationRpm" Format="F0" Style="width:80px" TValue="double" /></td>
                                                        <td><RadzenNumeric @bind-Value="row.Fre2" Format="F1" Style="width:90px" TValue="double" /></td>
                                                        <td><RadzenNumeric @bind-Value="row.StiffnessY" Format="F3" Style="width:90px" TValue="double" /></td>
                                                        <td class="col-diff">@row.FreqDiff.ToString("F1")</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </RadzenCard>

                                @* Kết quả ABCD *@
                                @if (_abcdCalculated)
                                {
                                    <RadzenRow Gap="1rem">
                                        <RadzenColumn Size="12" SizeMD="4">
                                            <RadzenCard class="rz-border-radius-6" Style="border-left: 4px solid var(--rz-primary)">
                                                <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3">📐 Kết quả tính toán</RadzenText>
                                                <RadzenStack Gap="0.5rem">
                                                    <RadzenRow>
                                                        <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption" style="color:var(--rz-text-secondary-color)">Stiffness vs Frequency</RadzenText><RadzenText TextStyle="TextStyle.Body2" style="font-family:monospace">Y = A·Z + B</RadzenText></RadzenColumn>
                                                        <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption" style="color:var(--rz-text-secondary-color)">Belt Rotation vs Freq Diff</RadzenText><RadzenText TextStyle="TextStyle.Body2" style="font-family:monospace">R = C·S + D</RadzenText></RadzenColumn>
                                                    </RadzenRow>
                                                    <RadzenRow class="rz-mt-2">
                                                        <RadzenColumn Size="3"><div class="abcd-box abcd-a"><span class="abcd-label">A</span><span class="abcd-value">@_resultAB.Slope.ToString("F3")</span></div></RadzenColumn>
                                                        <RadzenColumn Size="3"><div class="abcd-box abcd-b"><span class="abcd-label">B</span><span class="abcd-value">@_resultAB.Intercept.ToString("F3")</span></div></RadzenColumn>
                                                        <RadzenColumn Size="3"><div class="abcd-box abcd-c"><span class="abcd-label">C</span><span class="abcd-value">@_resultCD.Slope.ToString("F3")</span></div></RadzenColumn>
                                                        <RadzenColumn Size="3"><div class="abcd-box abcd-d"><span class="abcd-label">D</span><span class="abcd-value">@_resultCD.Intercept.ToString("F3")</span></div></RadzenColumn>
                                                    </RadzenRow>
                                                    <RadzenRow class="rz-mt-1">
                                                        <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">R² = <strong>@_resultAB.R2.ToString("F4")</strong></RadzenText></RadzenColumn>
                                                        <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">R² = <strong>@_resultCD.R2.ToString("F4")</strong></RadzenText></RadzenColumn>
                                                    </RadzenRow>
                                                    <RadzenRow class="rz-mt-2">
                                                        <RadzenColumn Size="12">
                                                            <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false" Size="AlertSize.ExtraSmall">
                                                                <strong>Công thức F (Belt wear):</strong><br />F = (−0.0006·X³ + 0.3·X² − 72.2·X) × (−0.001)
                                                            </RadzenAlert>
                                                        </RadzenColumn>
                                                    </RadzenRow>
                                                </RadzenStack>
                                            </RadzenCard>
                                        </RadzenColumn>
                                        <RadzenColumn Size="12" SizeMD="4">
                                            <RadzenCard>
                                                <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2">Stiffness vs Frequency (Y = A·Z + B)</RadzenText>
                                                <RadzenChart Style="height:220px">
                                                    <RadzenScatterSeries Data="@_chartABPoints" CategoryProperty="X" ValueProperty="Y" Title="Đo thực tế" Fill="var(--rz-primary)">
                                                        <TooltipTemplate Context="pt">Z=@pt.X.ToString("F3") → Y=@pt.Y.ToString("F1")</TooltipTemplate>
                                                    </RadzenScatterSeries>
                                                    <RadzenLineSeries Data="@_trendABPoints" CategoryProperty="X" ValueProperty="Y" Title="Y = A·Z + B" Stroke="var(--rz-danger)" StrokeWidth="2" />
                                                    <RadzenCategoryAxis><RadzenAxisTitle Text="Stiffness Z (kg)" /></RadzenCategoryAxis>
                                                    <RadzenValueAxis><RadzenAxisTitle Text="Frequency (CPM)" /></RadzenValueAxis>
                                                    <RadzenLegend Position="LegendPosition.Bottom" />
                                                </RadzenChart>
                                            </RadzenCard>
                                        </RadzenColumn>
                                        <RadzenColumn Size="12" SizeMD="4">
                                            <RadzenCard>
                                                <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-mb-2">Belt Rotation vs Freq Diff (R = C·S + D)</RadzenText>
                                                <RadzenChart Style="height:220px">
                                                    <RadzenScatterSeries Data="@_chartCDPoints" CategoryProperty="X" ValueProperty="Y" Title="Đo thực tế" Fill="var(--rz-success)">
                                                        <TooltipTemplate Context="pt">S=@pt.X.ToString("F1") → R=@pt.Y.ToString("F0")</TooltipTemplate>
                                                    </RadzenScatterSeries>
                                                    <RadzenLineSeries Data="@_trendCDPoints" CategoryProperty="X" ValueProperty="Y" Title="R = C·S + D" Stroke="var(--rz-danger)" StrokeWidth="2" />
                                                    <RadzenCategoryAxis><RadzenAxisTitle Text="Freq Diff S (CPM)" /></RadzenCategoryAxis>
                                                    <RadzenValueAxis><RadzenAxisTitle Text="Belt Rotation R (RPM)" /></RadzenValueAxis>
                                                    <RadzenLegend Position="LegendPosition.Bottom" />
                                                </RadzenChart>
                                            </RadzenCard>
                                        </RadzenColumn>
                                    </RadzenRow>
                                }

                            </RadzenStack>
                        </RadzenTabsItem>

                    </Tabs>
                </RadzenTabs>

            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

