@page "/revo"
@using GiamSat.Models
@using GiamSat.UI.Components
@using AppPermissions = GiamSat.Models.AppPermissions
@attribute [Authorize(Policy = AppPermissions.Revo_Home_View)]

<div class="dashboard-page-container">
<RadzenRow Gap="1rem">
    @if (_revoData == null || _revoData.Count == 0)
    {
        @* <RadzenColumn Size="12">
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-muted-color);">
                    Chưa có dữ liệu REVO.
                </RadzenText>
            </RadzenCard>
        </RadzenColumn> *@
        <RadzenColumn Size="12">
            <RadzenCard>
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                <RadzenText>Đang tải dữ liệu...</RadzenText>
            </RadzenCard>
        </RadzenColumn>
    }
    else
    {
        @foreach (var revo in _revoData.OrderBy(x => x.RevoId))
        {
            var dto = _shaftStats.TryGetValue(revo.RevoId, out var s) ? s : new APIClient.RevoGetTotalShaftCountDto { RevoId = revo.RevoId };
            <RadzenColumn Size="12" SizeMD="6" SizeLG="4" SizeXL="3">
                <RevoCard RevoData="@revo"
                          ShaftTotalCount="@dto.TotalShaftCurrentHour"
                          ShaftCurrentCount="@dto.TotalShaftFinishCurrentHour"
                          ShaftLastHourCount="@dto.TotalShaftFinshLastHour"
                          OnDetailClick="@(() => OnShowDetail(revo))" />
            </RadzenColumn>
        }
    }
</RadzenRow>
</div>
