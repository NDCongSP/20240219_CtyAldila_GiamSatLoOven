@inherits LayoutComponentBase

<RadzenComponents />
<RadzenContextMenu />
<RadzenDialog />
<RadzenNotification />
<RadzenTooltip />

<RadzenLayout Style="grid-template-areas: 'rz-sidebar rz-header' 'rz-sidebar rz-body' 'rz-sidebar rz-footer' position: relative">
    <RadzenHeader>
        <div class="container-fluid header-container">
            <div class="row g-0 align-items-center h-100">
                
                <!-- LEFT Section: Menu + Logo + Name -->
                <div class="col-auto header-left">
                    <div class="d-flex align-items-center gap-2">
                        <RadzenSidebarToggle Click="@(() => _sidebarExpanded = !_sidebarExpanded)" class="header-toggle" />
                        <RadzenImage Path="images/logoAldila.ico" class="header-logo" />
                        <RadzenLabel Text="Hệ Thống Giám Sát Nhà Máy" class="header-title" />
                    </div>
                </div>

                <!-- CENTER Section: Breadcrumb -->
                <div class="col header-center">
                    <div class="header-breadcrumb">
                        <RadzenBreadCrumb>
                            @if (GlobalVariable.BreadCrumbData != null && GlobalVariable.BreadCrumbData.Count > 0)
                            {
                                @foreach (var item in GlobalVariable.BreadCrumbData)
                                {
                                    <RadzenBreadCrumbItem Path="@item.Path" Text="@item.Text" />
                                }
                            }
                        </RadzenBreadCrumb>
                    </div>
                </div>

                <!-- RIGHT Section: Action Icons -->
                <div class="col-auto header-right">
                    <div class="d-flex align-items-center gap-2">
                        <RadzenLabel Text="@GlobalVariable.UserName" class="header-username d-none d-xl-block" />
                        <RadzenButton Icon="account_circle" 
                                    ButtonStyle="ButtonStyle.Light" 
                                    Variant="Variant.Text"
                                    Size="ButtonSize.Medium"
                                    Visible="@_changePass"
                                    Click="@(() => _navigationManager.NavigateTo("/dialogcardpageuserinfo"))"
                                    title="Thông tin người dùng"
                                    class="header-icon-btn" />
                        <RadzenButton Icon="people_alt" 
                                    ButtonStyle="ButtonStyle.Light" 
                                    Variant="Variant.Text"
                                    Size="ButtonSize.Medium"
                                    Visible="@_usersManager"
                                    Click="@(() => _navigationManager.NavigateTo("/usersmanager"))"
                                    title="Quản lý người dùng"
                                    class="header-icon-btn" />
                        <RadzenAppearanceToggle class="header-icon-btn" />
                        <RadzenButton Icon="logout" 
                                    ButtonStyle="ButtonStyle.Light" 
                                    Variant="Variant.Text"
                                    Size="ButtonSize.Medium"
                                    Click="@OnClickLogout"
                                    title="Đăng xuất"
                                    class="header-icon-btn" />
                    </div>
                </div>

            </div>
        </div>
    </RadzenHeader>
    <RadzenSidebar Responsive="false" @bind-Expanded="@_sidebarExpanded">
        <NavMenu />
    </RadzenSidebar>
    <RadzenBody>
        <div class="page-content-wrapper">
            @Body
        </div>
    </RadzenBody>
    <RadzenFooter>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End">
            <RadzenLabel>© 2024 Phuc Thinh Automation Solution Ltd. All Rights Reserved.</RadzenLabel>
        </RadzenStack>
    </RadzenFooter>
</RadzenLayout>
